node_modules

# Build output
build
/release
/release-linux

# Vite SPA output. Directory itself is tracked (via .gitkeep) so rust-embed
# compiles on a fresh clone before `npm --prefix web run build`.
/web/dist/*
!/web/dist/.gitkeep

# Generated stargazer API docs (built on demand via `npm run docs:stargazer`).
/web/src/stargazer/site

