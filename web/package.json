{
  "name": "barnguard-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Barnguard kiosk game — interactive touchscreen booth.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"require('fs').closeSync(require('fs').openSync('dist/.gitkeep','w'))\"",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src/",
    "prettier": "prettier --write --check 'src/**/*.*'",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@types/earcut": "^3.0.0",
    "earcut": "^2.2.4",
    "focus-trap": "^7.7.1",
    "lodash-es": "^4.17.22",
    "match-sorter": "^8.2.0",
    "svelte": "^5.46.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.0.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "sass": "^1.101.0",
    "svelte-check": "^4.3.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
